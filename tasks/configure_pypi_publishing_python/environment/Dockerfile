FROM ubuntu:24.04

RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep unzip && \
    pip3 install --break-system-packages pytest-json-ctrf pyyaml && \
    wget -q https://github.com/speakeasy-api/speakeasy/releases/download/v1.765.1/speakeasy_linux_amd64.zip -O /tmp/speakeasy.zip && \
    unzip -o /tmp/speakeasy.zip -d /tmp/speakeasy && \
    mv /tmp/speakeasy/speakeasy /usr/local/bin/speakeasy && \
    chmod +x /usr/local/bin/speakeasy && \
    rm -rf /tmp/speakeasy /tmp/speakeasy.zip && \
    wget -q https://github.com/mikefarah/yq/releases/download/v4.44.3/yq_linux_amd64 -O /usr/local/bin/yq && \
    chmod +x /usr/local/bin/yq && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user && chmod 0755 /home/user

RUN mkdir -p /home/user/project && \
    cat >/home/user/project/gen.yaml <<'EOF'
configVersion: 2.0.0
generation:
  sdkClassName: SDK
  baseServerURL: https://api.example.com
python:
  version: 0.1.0
  templateVersion: v2
  packageName: openapi
  moduleName: openapi
  authors:
    - Speakeasy
  description: Python Client SDK Generated by Speakeasy.
  homepage: https://example.com
  documentationUrl: https://example.com/docs
  license: Apache-2.0
EOF

LABEL Author="generate-harbor-tasks"
LABEL Description="Speakeasy CLI v1.765.1 environment with a seeded Python target gen.yaml in /home/user/project."

CMD ["/bin/bash", "-c", "trap : TERM INT; sleep infinity & wait"]

# Container contents:
#   - always required apt packages: curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep unzip
#   - always required pip3 packages: pytest-json-ctrf, pyyaml (used by tests)
#   - Speakeasy CLI v1.765.1 installed at /usr/local/bin/speakeasy (direct GitHub release download)
#   - yq v4.44.3 installed at /usr/local/bin/yq for YAML editing/verification
#   - /home/user/project: seeded Speakeasy project directory
#   - /home/user/project/gen.yaml: seeded gen.yaml with default python.packageName=openapi and python.authors=[Speakeasy]
