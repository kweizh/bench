FROM ubuntu:24.04

RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep \
        ffmpeg libxcb-shm0 libx11-xcb1 libx11-6 libxcb1 libxext6 libxrandr2 libxcomposite1 libxcursor1 libxdamage1 libxfixes3 libxi6 libgtk-3-0t64 libpangocairo-1.0-0 libpango-1.0-0 libatk1.0-0t64 libcairo-gobject2 libcairo2 libgdk-pixbuf-2.0-0 libxrender1 libasound2t64 libfreetype6 libfontconfig1 libdbus-1-3 libnss3 libnspr4 libatk-bridge2.0-0t64 libdrm2 libxkbcommon0 libatspi2.0-0t64 libcups2t64 libxshmfence1 libgbm1 && \
    ln -s /usr/bin/python3 /usr/bin/python && \
    curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    npm i -g agent-browser && \
    agent-browser install && \
    pip3 install --break-system-packages \
        pytest-json-ctrf \
        pytest-xprocess \
        pochi-verifier \
        altair \
        vega_datasets \
        pandas && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user && chmod 0755 /home/user

RUN mkdir -p /home/user/myproject && \
    cat >/home/user/myproject/solution.py <<'EOF'
"""Starter stub for the altair_cars_crossfilter_dashboard task.

Replace this stub with code that builds the required (A | B) & C cross-filter
dashboard on the cars dataset and saves it to /home/user/myproject/chart.html.
"""


def main() -> None:
    raise NotImplementedError(
        "Implement the cross-filtering dashboard and save it as chart.html."
    )


if __name__ == "__main__":
    main()
EOF

LABEL Author="generate-harbor-tasks"
LABEL Description="Vega-Altair task environment with altair, vega_datasets, pandas, and the pochi-verifier browser stack for the cars cross-filtering dashboard task."

CMD ["/bin/bash", "-c", "trap : TERM INT; sleep infinity & wait"]

# Container contents:
#   - always required apt packages: curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep
#   - always required pip3 packages: pytest-json-ctrf
#   - Vega-Altair stack: altair, vega_datasets, pandas
#   - Test runtime: pytest-xprocess (used by tests/test_final_state.py)
#   - Browser verification: pochi-verifier, agent-browser, Node.js v24, ffmpeg and browser libs
#   - /home/user/myproject: project directory containing the starter solution.py stub
