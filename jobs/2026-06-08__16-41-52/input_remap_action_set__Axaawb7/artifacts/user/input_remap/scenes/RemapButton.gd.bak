extends Control

## The action this button remaps.
@export var action_name: StringName = &""

## Reference to the label that displays the current binding text.
@onready var _label: Label = $Label


func _ready() -> void:
	_refresh_display()
	InputRemapper.action_rebound.connect(_on_action_rebound)
	$Button.pressed.connect(_on_pressed)


func _refresh_display() -> void:
	if not _label:
		return
	var ev: InputEvent = InputRemapper.get_action_event(action_name)
	if ev:
		_label.text = ev.as_text()
	else:
		_label.text = "Unbound"


## Enter listening mode and grab focus so we receive unhandled input.
func _on_pressed() -> void:
	_label.text = "Press a key..."
	set_process_unhandled_input(true)


func _unhandled_input(event: InputEvent) -> void:
	if event is InputEventKey or event is InputEventJoypadButton:
		# Only accept the press, not the release.
		if not event.is_pressed():
			return
		InputRemapper.rebind_action(action_name, event)
		# Stop listening.
		set_process_unhandled_input(false)
		_refresh_display()
		get_viewport().set_input_as_handled()


func _on_action_rebound(action: StringName, _event: InputEvent) -> void:
	if action == action_name:
		_refresh_display()
