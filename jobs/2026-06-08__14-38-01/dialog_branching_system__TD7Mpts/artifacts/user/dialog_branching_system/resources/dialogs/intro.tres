[ext_resource type="Script" path="res://scripts/DialogTree.gd" id="3_hvarb"]

[sub_resource type="Resource" id="Resource_xitww"]
script = ExtResource("2_djj3n")
label = "Talk to the merchant."
next_id = &"talk_merchant"
condition_flag = &""

[sub_resource type="Resource" id="Resource_ub2wb"]
script = ExtResource("2_djj3n")
label = "Examine the portal closely."
next_id = &"examine_portal"
condition_flag = &""

[sub_resource type="Resource" id="Resource_hqki4"]
script = ExtResource("1_qndfn")
id = &"start"
speaker = "Narrator"
text = "You stand before a mysterious glowing portal. A strange merchant is sitting nearby."
choices = Array[ExtResource("2_djj3n")]([SubResource("Resource_xitww"), SubResource("Resource_ub2wb")])
next_id = &""

[sub_resource type="Resource" id="Resource_nj20l"]
script = ExtResource("1_qndfn")
id = &"talk_merchant"
speaker = "Merchant"
text = "Hello, traveler! If you want to cross the portal safely, you will need this magic key. Take it!"
choices = Array[ExtResource("2_djj3n")]([])
next_id = &"get_key"

[sub_resource type="Resource" id="Resource_s1ymw"]
script = ExtResource("1_qndfn")
id = &"get_key"
speaker = "Narrator"
text = "The Merchant hands you a heavy golden key."
choices = Array[ExtResource("2_djj3n")]([])
next_id = &"portal_choices"

[sub_resource type="Resource" id="Resource_eykt2"]
script = ExtResource("1_qndfn")
id = &"examine_portal"
speaker = "Narrator"
text = "The portal crackles with unstable magical energy. It looks extremely dangerous without protection."
choices = Array[ExtResource("2_djj3n")]([])
next_id = &"portal_choices"

[sub_resource type="Resource" id="Resource_3y3g4"]
script = ExtResource("2_djj3n")
label = "Step into the portal blindly."
next_id = &"portal_death"
condition_flag = &""

[sub_resource type="Resource" id="Resource_gkj03"]
script = ExtResource("2_djj3n")
label = "Unlock the portal with the golden key."
next_id = &"portal_success"
condition_flag = &"has_key"

[sub_resource type="Resource" id="Resource_20fvg"]
script = ExtResource("2_djj3n")
label = "Go back and talk to the merchant."
next_id = &"talk_merchant"
condition_flag = &""

[sub_resource type="Resource" id="Resource_8r1vj"]
script = ExtResource("1_qndfn")
id = &"portal_choices"
speaker = "Narrator"
text = "What will you do next?"
choices = Array[ExtResource("2_djj3n")]([SubResource("Resource_3y3g4"), SubResource("Resource_gkj03"), SubResource("Resource_20fvg")])
next_id = &""

[sub_resource type="Resource" id="Resource_q1m4e"]
script = ExtResource("1_qndfn")
id = &"portal_death"
speaker = "Narrator"
text = "The unstable energy tears you apart. You are lost in time and space. Game Over."
choices = Array[ExtResource("2_djj3n")]([])
next_id = &""

[sub_resource type="Resource" id="Resource_g1ypn"]
script = ExtResource("1_qndfn")
id = &"portal_success"
speaker = "Narrator"
text = "The key fits perfectly! The portal stabilizes, and you step through into a beautiful new world."
choices = Array[ExtResource("2_djj3n")]([])
next_id = &""

[resource]
script = ExtResource("3_hvarb")
nodes = Array[ExtResource("1_qndfn")]([SubResource("Resource_hqki4"), SubResource("Resource_nj20l"), SubResource("Resource_s1ymw"), SubResource("Resource_eykt2"), SubResource("Resource_8r1vj"), SubResource("Resource_q1m4e"), SubResource("Resource_g1ypn")])
