{
  "name": "CLI Welcome zr-tcfrcky",
  "steps": [
    {
      "channel_key": "in-app",
      "channel_type": "in_app_feed",
      "name": "In-app welcome",
      "ref": "in_app_welcome",
      "template": {
        "action_url": "https://knock.app",
        "markdown_body@": "in_app_welcome/markdown_body.md"
      },
      "type": "channel"
    },
    {
      "channel_key": "mailtrap",
      "channel_type": "email",
      "name": "Email welcome",
      "ref": "email_welcome",
      "template": {
        "settings": {
          "attachment_key": "attachments",
          "layout_key": "default"
        },
        "subject": "Welcome to our app!",
        "html_body@": "email_welcome/html_body.html"
      },
      "type": "channel"
    }
  ],
  "trigger_frequency": "every_trigger",
  "__readonly": {
    "key": "cli-welcome-zr-tcfrcky",
    "active": true,
    "valid": true
  },
  "$schema": "https://schemas.knock.app/cli/workflow.json"
}
