{
  "config": {
    "view": {
      "continuousWidth": 300,
      "continuousHeight": 300
    }
  },
  "data": {
    "url": "https://vega.github.io/vega-datasets/data/population.json"
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "color": {
      "field": "sex",
      "legend": {
        "labelExpr": "datum.value == 1 ? 'Male' : 'Female'",
        "title": "Sex"
      },
      "scale": {
        "domain": [
          1,
          2
        ],
        "range": [
          "steelblue",
          "salmon"
        ]
      },
      "type": "nominal"
    },
    "x": {
      "axis": {
        "format": ",",
        "labelExpr": "abs(datum.value)",
        "title": "Population"
      },
      "field": "people_signed",
      "type": "quantitative"
    },
    "y": {
      "field": "age",
      "sort": "descending",
      "title": "Age",
      "type": "ordinal"
    }
  },
  "params": [
    {
      "name": "param_ef1d0f37fcab51ad",
      "bind": {
        "input": "select",
        "options": [
          1850,
          1860,
          1870,
          1880,
          1890,
          1900,
          1910,
          1920,
          1930,
          1940,
          1950,
          1960,
          1970,
          1980,
          1990,
          2000
        ],
        "name": "Year: "
      },
      "value": 1980
    }
  ],
  "transform": [
    {
      "calculate": "datum.sex == 1 ? -datum.people : datum.people",
      "as": "people_signed"
    },
    {
      "filter": "(datum.year === param_ef1d0f37fcab51ad)"
    }
  ],
  "$schema": "https://vega.github.io/schema/vega-lite/v6.4.1.json"
}