[gd_resource type="Resource" script_class="DialogTree" load_steps=22 format=3]

[ext_resource type="Script" path="res://scripts/DialogTree.gd" id="1_tree"]
[ext_resource type="Script" path="res://scripts/DialogNode.gd" id="2_node"]
[ext_resource type="Script" path="res://scripts/DialogChoice.gd" id="3_choice"]

[sub_resource type="Resource" script_class="DialogChoice" id="DialogChoice_1"]
script = ExtResource("3_choice")
label = "I'm a traveler"
next_id = &"traveler_response"
condition_flag = &""

[sub_resource type="Resource" script_class="DialogChoice" id="DialogChoice_2"]
script = ExtResource("3_choice")
label = "I'm here on business"
next_id = &"business_response"
condition_flag = &""

[sub_resource type="Resource" script_class="DialogNode" id="DialogNode_1"]
script = ExtResource("2_node")
id = &"intro_start"
speaker = "Guard"
text = "Halt! Who goes there? State your business!"
choices = [SubResource("DialogChoice_1"), SubResource("DialogChoice_2")]
next_id = &""

[sub_resource type="Resource" script_class="DialogNode" id="DialogNode_2"]
script = ExtResource("2_node")
id = &"traveler_response"
speaker = "Guard"
text = "A traveler, eh? We don't get many of those these days. The roads have been dangerous."
choices = []
next_id = &"ask_directions"

[sub_resource type="Resource" script_class="DialogNode" id="DialogNode_3"]
script = ExtResource("2_node")
id = &"business_response"
speaker = "Guard"
text = "Business, you say? The merchant quarter is open, but keep your nose clean."
choices = []
next_id = &"ask_directions"

[sub_resource type="Resource" script_class="DialogChoice" id="DialogChoice_3"]
script = ExtResource("3_choice")
label = "Where is the tavern?"
next_id = &"tavern_directions"
condition_flag = &""

[sub_resource type="Resource" script_class="DialogChoice" id="DialogChoice_4"]
script = ExtResource("3_choice")
label = "Tell me about the old tower."
next_id = &"tower_info"
condition_flag = &""

[sub_resource type="Resource" script_class="DialogChoice" id="DialogChoice_5"]
script = ExtResource("3_choice")
label = "I heard about a secret passage..."
next_id = &"secret_passage"
condition_flag = &"knows_secret"

[sub_resource type="Resource" script_class="DialogNode" id="DialogNode_4"]
script = ExtResource("2_node")
id = &"ask_directions"
speaker = "Player"
text = "Can you tell me where to go from here?"
choices = [SubResource("DialogChoice_3"), SubResource("DialogChoice_4"), SubResource("DialogChoice_5")]
next_id = &""

[sub_resource type="Resource" script_class="DialogNode" id="DialogNode_5"]
script = ExtResource("2_node")
id = &"tavern_directions"
speaker = "Guard"
text = "The Rusty Tankard? Straight down this road, take the second left. Tell the barkeep I sent you."
choices = []
next_id = &""

[sub_resource type="Resource" script_class="DialogNode" id="DialogNode_6"]
script = ExtResource("2_node")
id = &"tower_info"
speaker = "Guard"
text = "The old tower? That place is cursed. No one goes there anymore. But if you must... it's on the hill north of town."
choices = []
next_id = &""

[sub_resource type="Resource" script_class="DialogNode" id="DialogNode_7"]
script = ExtResource("2_node")
id = &"secret_passage"
speaker = "Guard"
text = "How do you know about that?! Fine... there's a hidden entrance behind the waterfall east of town. But you didn't hear it from me."
choices = []
next_id = &""

[resource]
script = ExtResource("1_tree")
nodes = [SubResource("DialogNode_1"), SubResource("DialogNode_2"), SubResource("DialogNode_3"), SubResource("DialogNode_4"), SubResource("DialogNode_5"), SubResource("DialogNode_6"), SubResource("DialogNode_7")]
start_id = &"intro_start"
