#!/usr/bin/env python

import os

# Build godot-cpp and import env from it.
env = SConscript("godot-cpp/SConstruct")

# Extension source files.
env.Append(CPPPATH=["src/"])
sources = Glob("src/*.cpp")

# Output library name follows godot-cpp naming conventions:
# lib<name>.<platform>.<target>.<arch>.so
if env["platform"] == "macos":
    library = env.SharedLibrary(
        "bin/libfastvectormath.{}.{}.framework/libfastvectormath.{}.{}".format(
            env["platform"], env["target"], env["platform"], env["target"]
        ),
        source=sources,
    )
else:
    library = env.SharedLibrary(
        "bin/libfastvectormath{}{}".format(env["suffix"], env["SHLIBSUFFIX"]),
        source=sources,
    )

Default(library)
