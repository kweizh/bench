; ── AnimationLibrary ──────────────────────────────────────────────────────────

[sub_resource type="AnimationLibrary" id="AnimLib_player"]
_data = {
&"idle": SubResource("Anim_idle"),
&"walk_north": SubResource("Anim_walk_north"),
&"walk_south": SubResource("Anim_walk_south"),
&"walk_east": SubResource("Anim_walk_east"),
&"walk_west": SubResource("Anim_walk_west"),
&"attack": SubResource("Anim_attack")
}

; ── AnimationNodeAnimation wrappers ──────────────────────────────────────────

[sub_resource type="AnimationNodeAnimation" id="NodeAnim_idle"]
animation = &"idle"

[sub_resource type="AnimationNodeAnimation" id="NodeAnim_walk_north"]
animation = &"walk_north"

[sub_resource type="AnimationNodeAnimation" id="NodeAnim_walk_south"]
animation = &"walk_south"

[sub_resource type="AnimationNodeAnimation" id="NodeAnim_walk_east"]
animation = &"walk_east"

[sub_resource type="AnimationNodeAnimation" id="NodeAnim_walk_west"]
animation = &"walk_west"

[sub_resource type="AnimationNodeAnimation" id="NodeAnim_attack"]
animation = &"attack"

; ── BlendSpace2D for locomotion ───────────────────────────────────────────────
; Godot 4 serialises each point as  blend_point_N/node  and  blend_point_N/pos
; (no "blend_points/" prefix and no "/count" key).
; Points: idle(0,0)  north(0,-1)  south(0,1)  east(1,0)  west(-1,0)

[sub_resource type="AnimationNodeBlendSpace2D" id="BlendSpace2D_loco"]
blend_point_0/node = SubResource("NodeAnim_idle")
blend_point_0/pos = Vector2(0, 0)
blend_point_1/node = SubResource("NodeAnim_walk_north")
blend_point_1/pos = Vector2(0, -1)
blend_point_2/node = SubResource("NodeAnim_walk_south")
blend_point_2/pos = Vector2(0, 1)
blend_point_3/node = SubResource("NodeAnim_walk_east")
blend_point_3/pos = Vector2(1, 0)
blend_point_4/node = SubResource("NodeAnim_walk_west")
blend_point_4/pos = Vector2(-1, 0)

; ── State-machine transitions ─────────────────────────────────────────────────
; switch_mode: IMMEDIATE=0  SYNC=1  AT_END=2
; advance_mode: DISABLED=0  ENABLED=1  AUTO=2

; Locomotion → Attack : advance_mode=ENABLED (1) + boolean condition
[sub_resource type="AnimationNodeStateMachineTransition" id="Trans_loco_to_attack"]
switch_mode = 0
advance_mode = 1
advance_condition = &"condition_attack"

; Attack → Locomotion : switch_mode=AT_END (2), advance_mode=AUTO (2)
[sub_resource type="AnimationNodeStateMachineTransition" id="Trans_attack_to_loco"]
switch_mode = 2
advance_mode = 2

; ── AnimationNodeStateMachine root ───────────────────────────────────────────
; Godot 4 serialises "transitions" as a flat Array:
;   ["from_a", "to_a", TransitionObj_a, "from_b", "to_b", TransitionObj_b, ...]

[sub_resource type="AnimationNodeStateMachine" id="StateMachine_root"]
states/Locomotion/node = SubResource("BlendSpace2D_loco")
states/Locomotion/position = Vector2(-200, 0)
states/Attack/node = SubResource("NodeAnim_attack")
states/Attack/position = Vector2(200, 0)
transitions = ["Locomotion", "Attack", SubResource("Trans_loco_to_attack"), "Attack", "Locomotion", SubResource("Trans_attack_to_loco")]
start_node = &"Locomotion"
end_node = &"[end]"

; ── Node tree ─────────────────────────────────────────────────────────────────

[node name="Player" type="Node"]

[node name="AnimationPlayer" type="AnimationPlayer" parent="."]
libraries = {
&"": SubResource("AnimLib_player")
}

[node name="AnimationTree" type="AnimationTree" parent="."]
tree_root = SubResource("StateMachine_root")
anim_player = NodePath("../AnimationPlayer")
active = false

[node name="PlayerAnimController" type="Node" parent="."]
script = ExtResource("1_pactrl")
