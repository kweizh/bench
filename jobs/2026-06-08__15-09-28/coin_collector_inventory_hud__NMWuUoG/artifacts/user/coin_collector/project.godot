; Engine configuration file.
; It's best edited using the editor GUI and not directly,
; but the file format allows total manual editing.
; Resource types and IDs are not changed, only the content.
; Format:
;   [section] ; section goes between []
;   param=value ; assignment

[application]

config/name="CoinCollector"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

Inventory="*res://autoloads/Inventory.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
