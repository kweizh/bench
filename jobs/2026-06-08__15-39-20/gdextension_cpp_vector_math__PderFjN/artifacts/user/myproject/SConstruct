#!/usr/bin/env python
import os

env = SEnvironment() if 'SEnvironment' in dir() else Environment()

opts = Variables()
opts.Add(EnumVariable('target', 'Build target', 'template_debug', allowed_values=['template_debug', 'template_release']))
opts.Add(EnumVariable('platform', 'Target platform', '', allowed_values=['', 'linux', 'macos', 'windows', 'android', 'ios']))
opts.Add(EnumVariable('arch', 'Target architecture', '', allowed_values=['', 'x86_32', 'x86_64', 'arm32', 'arm64', 'rv64', 'ppc32', 'ppc64', 'wasm32']))
opts.Update(env)

env.Append(CPPPATH=['src'])

sources = Glob('src/*.cpp')

# godot-cpp
godot_cpp_env = SConscript('godot-cpp/SConstruct')

# We need to use the godot-cpp environment
env = godot_cpp_env.Clone()
env.Append(CPPPATH=['src'])

library = env.SharedLibrary(
    target='bin/libfast_vector_math{}{}'.format(env['suffix'], env['SHLIBSUFFIX']),
    source=sources,
)

Default(library)
