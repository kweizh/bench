# Test script for the libGDX headless geometry CLI

# Define a unit square (CCW)
POLY square 0 0 1 0 1 1 0 1

# Define a triangle that overlaps the square
POLY triangle 0.5 0.5 1.5 0.5 1.0 1.5

# Define a separate polygon far away
POLY far 10 10 11 10 11 11 10 11

# Check overlap
OVERLAP square triangle
OVERLAP square far

# Point containment
CONTAINS square 0.5 0.5
CONTAINS square 2.0 2.0

# Segment intersection: diagonals of the unit square
SEGMENTS 0 0 1 1 1 0 0 1

# Segment miss: two parallel horizontal segments
SEGMENTS 0 0 1 0 0 1 1 1

# Area of the unit square
AREA square

# Error cases
OVERLAP square missing
CONTAINS undefined 1 1
AREA nothere
UNKNOWN_COMMAND
