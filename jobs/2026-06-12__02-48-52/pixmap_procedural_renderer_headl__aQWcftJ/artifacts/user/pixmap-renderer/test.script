# Test script for the pixmap renderer
SIZE 200 150

# Fill background with dark blue
FILL 20 30 80 255

# White rectangle border area
RECT 10 10 180 130 255 255 255 255

# Red filled rectangle
RECT 20 20 80 60 220 50 50 255

# Green filled circle
CIRCLE 150 75 40 50 200 50 255

# Blue diagonal line
LINE 20 110 180 20 50 100 220 255

# Single yellow pixel
PIXEL 100 75 255 255 0 255
